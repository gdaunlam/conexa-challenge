# `pre-push` corre verificaciones antes de empujar al remoto.
#
# Tres chequeos, todos requeridos:
# 1. `pnpm lint` - reglas de ESLint, incluido el bloqueo de `.only` en
#    cualquier variante (CallExpression con `.only` y bracket notation).
# 2. Grep de `.only(` en specs - la barrera REAL contra `.only`, porque
#    Jest 29.7 no honra `forbidOnly: true` (esa opcion llega en Jest 30).
#    Sin este check, `it.only(...)` en un spec pasaria el pre-push y solo
#    el dev se enteraria al ver el resto de la suite "skipped".
# 3. `pnpm test` - la suite completa.

set -e

pnpm lint

if grep -rE --include='*.spec.ts' -e '\.only[[:space:]]*\(' -e '\[['"'"'"](only|fit)['"'"']\][[:space:]]*\(' -e '\b(fdescribe|fit)[[:space:]]*\(' src/; then
  echo ""
  echo "FAIL: .only / fit / fdescribe detectado en un spec."
  echo "  Removelo antes de pushear: silencia el resto de la suite y rompe el CI."
  exit 1
fi

pnpm test
