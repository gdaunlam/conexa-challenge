# ============================================================
# ⚠️  THESE VALUES ARE FOR DEV ONLY. THEY DO NOT PASS THE
# PRODUCTION RULES (see src/config/env.validation.ts). In
# production `validateEnv` rejects this file and demands real
# secrets.
# ============================================================

# HTTP server port
PORT=3000

# Runtime environment: development | production | test
NODE_ENV=development

# PostgreSQL host
DATABASE_HOST=localhost

# PostgreSQL port
DATABASE_PORT=5432

# PostgreSQL user
DATABASE_USER=postgres

# PostgreSQL password. No default: this file defines one for
# local dev only. In production `validateEnv` requires >= 12
# chars and forbids trivial words (postgres, password, admin,
# changeme, secret).
DATABASE_PASSWORD=dev-only-db-password

# Database name
DATABASE_NAME=movies_db

# Secret used to sign JWTs. No insecure default: this file
# defines one for local dev only. In production `validateEnv`
# requires >= 32 chars.
JWT_SECRET=dev-only-jwt-secret-not-for-production

# JWT access token TTL in seconds (1 hour = 3600)
JWT_TTL_SECONDS=3600

# bcrypt cost factor (valid range: 4-15)
BCRYPT_COST=10
