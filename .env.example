# ============================================================
# ⚠️  ESTOS VALORES SON SOLO PARA DEV. NO PASAN LAS REGLAS DE
# PRODUCCION (ver src/config/env.validation.ts). En produccion
# `validateEnv` rechaza este archivo y exige secretos reales.
# ============================================================

# Puerto del servidor HTTP
PORT=3000

# Entorno de ejecucion: development | production | test
NODE_ENV=development

# Host del PostgreSQL
DATABASE_HOST=localhost

# Puerto del PostgreSQL
DATABASE_PORT=5432

# Usuario del PostgreSQL
DATABASE_USER=postgres

# Password del PostgreSQL. Sin default: este archivo define uno solo para
# dev local. En produccion `validateEnv` exige >= 12 chars y que no
# contenga palabras triviales (postgres, password, admin, changeme, secret).
DATABASE_PASSWORD=dev-only-db-password

# Nombre de la base de datos
DATABASE_NAME=movies_db

# Secret para firmar JWT. Sin default inseguro: este archivo define uno
# solo para dev local. En produccion `validateEnv` exige >= 32 chars.
JWT_SECRET=dev-only-jwt-secret-not-for-production

# TTL del access token JWT en segundos (1 hora = 3600)
JWT_TTL_SECONDS=3600

# Cost factor de bcrypt (rango valido: 4-15)
BCRYPT_COST=10

# Origins permitidos para CORS, como CSV. Opcional en dev (default: `*`
# con un warning logueado una sola vez). Obligatorio en produccion:
# `validateEnv` rechaza arrancar prod sin este valor.
# Ejemplo: CORS_ORIGINS=https://app.example.com,https://admin.example.com
# CORS_ORIGINS=
